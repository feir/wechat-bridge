# Required: comma-separated WeChat user IDs allowed to interact
WECHAT_ALLOWED_USERS=

# Claude model (default: sonnet)
CLAUDE_MODEL=sonnet

# Claude subprocess timeout in seconds (default: 300)
CLAUDE_TIMEOUT=300

# Max concurrent Claude subprocesses (default: 3)
WECHAT_MAX_CONCURRENT=3

# State file directory (default: ~/.local/share/wechat-bridge)
WECHAT_STATE_DIR=

# Per-invocation cost cap in USD (0 = no limit)
CLAUDE_MAX_BUDGET_USD=0

# Primary user (full permissions, no workspace isolation)
# Defaults to first user in WECHAT_ALLOWED_USERS
# WECHAT_PRIMARY_USER=

# Guest user per-invocation cost cap in USD (default: 1.0)
CLAUDE_GUEST_MAX_BUDGET_USD=1.0

# Custom system prompt (optional, overrides default WeChat-optimized prompt)
# WECHAT_SYSTEM_PROMPT=

# System prompt from file (takes precedence over WECHAT_SYSTEM_PROMPT)
# Useful for multi-line prompts / agent personalities
# WECHAT_SYSTEM_PROMPT_FILE=

# Credentials file path (default: ~/.config/wechat-bridge/credentials.json)
# Set per-instance for multi-bot deployments
# WECHAT_CREDENTIALS_FILE=

# Feishu notification chat ID (optional, for session expiry alerts)
FEISHU_NOTIFY_CHAT_ID=
